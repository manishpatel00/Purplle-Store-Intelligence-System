# .env.example — copy to .env and fill in values before running

# --- Database (Required) ---
POSTGRES_USER=si_user
POSTGRES_PASSWORD=changeme_min32chars_required_here
POSTGRES_DB=store_intel
# Production URL within Docker network
DATABASE_URL=postgresql+asyncpg://si_user:changeme@postgres/store_intel

# --- Redis Stream (Required) ---
REDIS_URL=redis://redis:6379/0

# --- API Configuration ---
SECRET_KEY=generate_with_openssl_rand_hex_32_minimum_32_chars
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
VERSION=0.1.0

# --- CORS Settings ---
CORS_ORIGINS=http://localhost:5173

# --- Detection Pipeline Settings ---
DATA_DIR=./data                   # local mount for CCTV files and layouts
MODEL_PATH=yolov8s.pt             # downloaded by `make weights`; NOT committed
DETECTION_TARGET_FPS=5            # frames/sec to process; 15 for final eval
INFERENCE_BATCH_SIZE=8            # frames per YOLO forward pass

# --- Business Logic Settings ---
POS_CSV_PATH=./data/pos_transactions.csv
POS_MATCH_MIN_SCORE=0.6           # minimum score to accept a POS correlation
REENTRY_WINDOW_SECONDS=900        # 15 minutes
HANDOFF_WINDOW_SECONDS=20         # cross-camera deduplication window

# --- Rate Limiting ---
INGEST_RATE_LIMIT=200/minute

# --- Metrics / Prometheus Configuration ---
PROMETHEUS_ENABLED=false          # set true to enable /metrics endpoint
SENTRY_DSN=                       # leave empty for local dev
